\f3\b REVISED ARCHITECTURE - CROSS-VISIBILITY & CHILD SAFETY
\f1\b0 \
\
  \cf6 1. ENHANCED VISIBILITY MODEL\cf4 \
\
  \cf6 Visibility Levels for Coaches/Instructors\cf4 \
\
  \cf12 -- Revised athlete_relationships table with granular permissions\cf4 \
  \cf13 CREATE\cf4  \cf13 TABLE\cf4  athlete_relationships (\
    id UUID \cf13 PRIMARY\cf4  KEY \cf13 DEFAULT\cf4  gen_random_uuid(),\
    athlete_id UUID \cf13 REFERENCES\cf4  athlete_profiles(id),\
    user_id UUID \cf13 REFERENCES\cf4  auth.users(id),\
    relationship_type \cf8 VARCHAR\cf4 (\cf12 50\cf4 ),\
\
    \cf12 -- Granular visibility permissions\cf4 \
    visibility_level \cf8 VARCHAR\cf4 (\cf12 50\cf4 ) \cf13 DEFAULT\cf4  \cf14 'own_sessions_only'\cf4 ,\
    \cf12 -- Options: 'own_sessions_only', 'team_schedule', 'full_schedule', 'full_with_metrics'\cf4 \
\
    can_view_personal_info \cf8 BOOLEAN\cf4  \cf13 DEFAULT\cf4  \cf13 false\cf4 ,\
    can_view_medical_info \cf8 BOOLEAN\cf4  \cf13 DEFAULT\cf4  \cf13 false\cf4 ,\
    can_view_location_details \cf8 BOOLEAN\cf4  \cf13 DEFAULT\cf4  \cf13 false\cf4 ,\
    can_view_other_coaches \cf8 BOOLEAN\cf4  \cf13 DEFAULT\cf4  \cf13 false\cf4 ,\
\
    \cf12 -- Time-boxed permissions\cf4 \
    valid_from \cf8 DATE\cf4  \cf13 NOT\cf4  \cf13 NULL\cf4  \cf13 DEFAULT\cf4  \cf15 CURRENT_DATE\cf4 ,\
    valid_until \cf8 DATE\cf4 , \cf12 -- NULL = indefinite, but parent can revoke\cf4 \
\
    \cf12 -- Audit fields\cf4 \
    granted_by UUID \cf13 REFERENCES\cf4  auth.users(id), \cf12 -- Parent who granted\cf4 \
    granted_at TIMESTAMPTZ \cf13 DEFAULT\cf4  NOW(),\
    last_accessed TIMESTAMPTZ,\
    access_count \cf8 INTEGER\cf4  \cf13 DEFAULT\cf4  \cf12 0\cf4 \
  );\
\
  \cf6 2. MINIMUM PRIVILEGE VISIBILITY MATRIX\cf4 \
\
  VISIBILITY LEVELS:\
\
  Level 1: "Own Sessions Only" (DEFAULT)\
  - Coach sees: Only sessions they personally conducted\
  - Instructor sees: Only recovery sessions they led\
  - Cannot see: Other coaches, other sessions, personal details\
\
  Level 2: "Team Schedule"\
  - Coach sees: All team training sessions, matches for their sport\
  - Cannot see: Other sports, recovery sessions, personal info\
\
  Level 3: "Sport Overview"\
  - Coach sees: All sessions for their sport across all teams\
  - Instructor sees: All recovery work for athletes in their care\
  - Cannot see: Other sports, detailed metrics\
\
  Level 4: "Full Schedule" (REQUIRES EXPLICIT PARENT CONSENT)\
  - See all training across all sports\
  - See all recovery sessions\
  - See attendance patterns\
  - Cannot see: Medical info, personal contact details\
\
  Level 5: "Full with Metrics" (RARE - MEDICAL PROFESSIONAL)\
  - Everything including load metrics\
  - Injury history\
  - Recovery notes\
\
  \cf6 3. SAFETY CONTROLS & RISK MITIGATION\cf4 \
\
  \cf6 A. Data Minimization\cf4 \
\
  \cf12 // Information deliberately NOT stored/shown:\cf4 \
  \cf13 interface\cf4  ExcludedData \{\
    \cf15 home_address\cf4 : \cf15 never\cf4 ;  \cf12 // Use club/venue addresses only\cf4 \
    school_name: \cf15 never\cf4 ;   \cf12 // Not relevant\cf4 \
    phone_numbers: \cf15 never\cf4 ; \cf12 // Parent contact only through system\cf4 \
    social_media: \cf15 never\cf4 ;  \cf12 // No social linking\cf4 \
    photos: \cf15 never\cf4 ;        \cf12 // Unless separate photo consent\cf4 \
  \}\
\
  \cf12 // Location handling\cf4 \
  \cf13 interface\cf4  SafeLocation \{\
    \cf15 venue_name\cf4 : \cf15 string\cf4 ;      \cf12 // "St. Mary's GAA Club"\cf4 \
    venue_type: \cf15 string\cf4 ;      \cf12 // "Sports Facility"\cf4 \
    \cf12 // NO street addresses shown to coaches\cf4 \
  \}\
\
  \cf6 B. Access Monitoring & Alerts\cf4 \
\
  \cf13 CREATE\cf4  \cf13 TABLE\cf4  access_audit_log (\
    id UUID \cf13 PRIMARY\cf4  KEY \cf13 DEFAULT\cf4  gen_random_uuid(),\
    user_id UUID \cf13 NOT\cf4  \cf13 NULL\cf4 ,\
    athlete_id UUID \cf13 NOT\cf4  \cf13 NULL\cf4 ,\
    action \cf8 VARCHAR\cf4 (\cf12 50\cf4 ), \cf12 -- 'view_schedule', 'view_metrics', 'export_data'\cf4 \
    ip_address INET,\
    user_agent TEXT,\
    accessed_at TIMESTAMPTZ \cf13 DEFAULT\cf4  NOW()\
  );\
\
  \cf12 -- Alert triggers:\cf4 \
  \cf12 -- 1. Unusual access patterns (e.g., accessing at unusual hours)\cf4 \
  \cf12 -- 2. Bulk data access attempts\cf4 \
  \cf12 -- 3. Access outside normal relationship scope\cf4 \
  \cf12 -- 4. Repeated access to single athlete profile\cf4 \
\
  \cf6 C. Parent Control Dashboard\cf4 \
\
  \cf13 interface\cf4  ParentControls \{\
    \cf12 // Granular permission toggles\cf4 \
    \cf15 permissions\cf4 : \{\
      \cf15 showFullName\cf4 : \cf15 boolean\cf4 ;        \cf12 // vs initials only\cf4 \
      showAge: \cf15 boolean\cf4 ;             \cf12 // vs age group only\cf4 \
      showExactTimes: \cf15 boolean\cf4 ;      \cf12 // vs "Morning/Afternoon"\cf4 \
      showVenueDetails: \cf15 boolean\cf4 ;    \cf12 // vs "Training Ground A"\cf4 \
      allowDataExport: \cf15 boolean\cf4 ;\
      allowCrossCoachVisibility: \cf15 boolean\cf4 ;\
    \};\
\
    \cf12 // Time-boxing\cf4 \
    reviewSchedule: \cf14 'weekly'\cf4  | \cf14 'monthly'\cf4  | \cf14 'quarterly'\cf4 ;\
    autoExpirePermissions: \cf15 number\cf4 ; \cf12 // days\cf4 \
\
    \cf12 // Notifications\cf4 \
    notifyOnAccess: \cf15 boolean\cf4 ;\
    weeklyAccessReport: \cf15 boolean\cf4 ;\
    unusualActivityAlerts: \cf15 boolean\cf4 ;\
  \}\
\
  \cf6 4. PROGRESSIVE INFORMATION DISCLOSURE\cf4 \
\
  \cf6 Default View (Maximum Safety)\cf4 \
\
  Athlete: J.M. (U14)\
  Mon: Team Training (90 min) - High Intensity\
  Wed: Match (80 min) - High Intensity\
  Thu: Recovery Session (45 min)\
\
  Weekly Load: Above Average \uc0\u9888 \u65039 \
\
  \cf6 With Parent Permission\cf4 \
\
  Athlete: John Murphy (Age 14, DOB hidden)\
  Mon: GAA Training @ Club Grounds (3:30-5:00 PM) - High Intensity\
       Coach: Pat O'Brien\
  Wed: Match vs St. Peters @ Home (4:00 PM) - High Intensity\
  Thu: Pilates Recovery @ Bassline Studio (5:00 PM)\
       Instructor: Mary Kelly\
       Focus: Hip mobility, Core stability\
\
  Weekly Load: 580 (Target: 400-500)\
  Other Activities: Soccer (Tues, Fri)\
\
  \cf6 5. RELATIONSHIP VERIFICATION WORKFLOW\cf4 \
\
  1. Coach creates team\
  2. Coach adds athlete (name + DOB only)\
  3. System generates unique claim code\
  4. Parent receives invite with claim code\
  5. Parent verifies:\
     - Their identity\
     - Relationship to child\
     - Contact info for verification\
  6. Parent sets permission levels:\
     - What coaches can see\
     - Duration of access\
     - Notification preferences\
  7. System sends confirmation to:\
     - Parent email\
     - Secondary guardian (optional)\
  8. Quarterly review reminder to parent\
\
  \cf6 6. EMERGENCY OVERRIDE SCENARIOS\cf4 \
\
  \cf12 -- Emergency contact info (encrypted, parent-controlled)\cf4 \
  \cf13 CREATE\cf4  \cf13 TABLE\cf4  emergency_access (\
    athlete_id UUID \cf13 PRIMARY\cf4  KEY,\
    encrypted_contact BYTEA, \cf12 -- Encrypted with parent's key\cf4 \
    medical_conditions_summary TEXT, \cf12 -- "Asthma - inhaler required"\cf4 \
    emergency_procedure TEXT,\
    \cf12 -- Only shown in emergency mode with audit trail\cf4 \
  );\
\
  \cf6 7. ANONYMIZATION OPTIONS\cf4 \
\
  For maximum safety, parents can choose:\
\
  \cf13 interface\cf4  AnonymizationOptions \{\
    \cf15 displayMode\cf4 : \cf14 'full_name'\cf4  | \cf14 'initials'\cf4  | \cf14 'athlete_code'\cf4 ;\
    \cf12 // Athlete code example: "TEAM01-2024-AF" (team-year-random)\cf4 \
\
    scheduleDetail: \cf14 'exact'\cf4  | \cf14 'blocks'\cf4  | \cf14 'counts_only'\cf4 ;\
    \cf12 // Blocks: "Morning Training", "Afternoon Recovery"\cf4 \
    \cf12 // Counts: "3 sessions this week"\cf4 \
\
    shareWithinTeam: \cf15 boolean\cf4 ; \cf12 // Other parents can see\cf4 \
    shareAcrossSports: \cf15 boolean\cf4 ; \cf12 // Other sport coaches can see\cf4 \
  \}\
\
  \cf6 8. LEGAL COMPLIANCE ADDITIONS\cf4 \
\
  \cf12 -- Consent tracking with versioning\cf4 \
  \cf13 CREATE\cf4  \cf13 TABLE\cf4  consent_records (\
    id UUID \cf13 PRIMARY\cf4  KEY \cf13 DEFAULT\cf4  gen_random_uuid(),\
    athlete_id UUID \cf13 NOT\cf4  \cf13 NULL\cf4 ,\
    parent_id UUID \cf13 NOT\cf4  \cf13 NULL\cf4 ,\
    consent_type \cf8 VARCHAR\cf4 (\cf12 50\cf4 ), \cf12 -- 'data_sharing', 'photo', 'medical'\cf4 \
    version \cf8 VARCHAR\cf4 (\cf12 10\cf4 ),\
    granted_at TIMESTAMPTZ,\
    expires_at TIMESTAMPTZ,\
    consent_text TEXT, \cf12 -- Store exact text consented to\cf4 \
    ip_address INET,\
    withdrawn_at TIMESTAMPTZ\
  );\
\
  \cf6 9. RECOMMENDED SAFETY DEFAULTS\cf4 \
\
  1. 
\f3\b Coaches see by default:
\f1\b0 \
    - Initials only (not full names)\
    - Their own team sessions only\
    - General intensity levels (not specific metrics)\
    - No other coaches' names\
    - No venue addresses\
  2. 
\f3\b Parents must explicitly opt-in for:
\f1\b0 \
    - Full name display\
    - Cross-coach visibility\
    - Exact times/locations\
    - Medical information sharing\
    - Photo permissions\
  3. 
\f3\b Automatic safety features:
\f1\b0 \
    - Access logs emailed weekly to parents\
    - Permissions expire after school term (3 months)\
    - Unusual access patterns trigger alerts\
    - Data export requires 2FA + parent notification\
    - Coach changes require re-consent\
\
  This revised architecture prioritizes child safety while still enabling the cross-visibility needed for effective training load management. The key principle is: start with minimum access\
   and let parents explicitly grant more as needed.\
