# Test Environment Variables for Playwright E2E Tests
# Copy this file to .env.test and fill in your test account credentials

# Required: Test account credentials for E2E tests
PLAYWRIGHT_TEST_USER_EMAIL=your-test-email@example.com
PLAYWRIGHT_TEST_USER_PASSWORD=your-secure-test-password

# Optional: Override the base URL for testing
# PLAYWRIGHT_BASE_URL=http://localhost:5173

# Note: Never commit actual credentials to version control
# Always use strong, unique passwords for test accounts
# Consider using a password manager to generate and store test credentials