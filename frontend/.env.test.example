# Playwright Test Environment Variables
# Copy this file to .env.test and add your actual credentials
# .env.test is gitignored and will not be committed

# Test user credentials for multi-role registration tests
PLAYWRIGHT_TEST_USER_EMAIL=your-test@example.com
PLAYWRIGHT_TEST_USER_PASSWORD=YourPassword123!

# Test environment (optional)
# TEST_ENV=development
# TEST_ENV=production
