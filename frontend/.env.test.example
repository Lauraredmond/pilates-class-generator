# Test Environment Variables for Playwright E2E Tests
# Copy this file to .env.test and fill in your test account credentials

# Required: Primary test account credentials for E2E tests
PLAYWRIGHT_TEST_USER_EMAIL=your-test-email@example.com
PLAYWRIGHT_TEST_USER_PASSWORD=your-secure-test-password

# Optional: Secondary test account (for multi-user tests)
# PLAYWRIGHT_TEST_USER2_EMAIL=second-test@example.com
# PLAYWRIGHT_TEST_USER2_PASSWORD=another-secure-password

# Optional: Admin test account (for admin-only features tests)
# PLAYWRIGHT_ADMIN_EMAIL=admin-test@example.com
# PLAYWRIGHT_ADMIN_PASSWORD=admin-secure-password

# Optional: Override the base URL for testing
# PLAYWRIGHT_BASE_URL=http://localhost:5173

# CI/CD Configuration:
# For GitHub Actions, add these as repository secrets:
# Settings → Secrets → Actions → New repository secret

# Security Notes:
# - Never commit actual credentials to version control
# - Always use strong, unique passwords for test accounts
# - Consider using a password manager to generate and store test credentials
# - The .env.test file should be in .gitignore (never commit it)